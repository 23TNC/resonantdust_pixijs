recipe soul_forest_work_faculty
  implicit
    player
    soul (soul)

  input
    tile (forest|plain)where(food|wood)
    cards
      host (work)where(ready&labor)
      faculty (faculty)where(ready&(food|wood)&corpus)
      item1? (requisite)where(ready&(food|wood|corpus))
      item2? (requisite)where(ready&(food|wood|corpus))

  craft_time 30

  on_start
    set(host.ready,false)
    set(host.show_progress,true)
  end

  on_complete
    if(gt(cards.wood,3),give(player.card_id,log,rand(1,3)))
    if(gt(cards.food,2),give(player.card_id,food,rand(0,5)))
    enqueue(fatigue,faculty.card_id)
    set(host.ready,true)
    set(host.show_progress,false)
  end
end

recipe fatigue
  input
    host (faculty)where(gt(max_fatigue,0))

  craft_time host.max_fatigue

  on_start
    set(host.ready,false)
    set(host.show_progress,true)
  end

  on_complete
    set(host.ready,true)
    set(host.show_progress,false)
  end
end