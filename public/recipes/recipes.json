[
  {
    "id": "Forest_Work_Health",
    "input": [ 
      { "Forest": { "if": [ "input[1].impassable" ] } }, 
      { "Work": {
          "and": [
            { "if": [ "input[2].ready" ] },
            { "ge": [ { "dist": [ "input[0].player.position", "input[1].position" ] }, "0" ] }
          ]
        } 
      },
      { "Health": { "if": [ "input[3].ready" ] } } 
    ],
    "craft_time": { "value": [ "30" ] },
    "on_start": [
      { "set": [ "input[2].ready", "false" ] },
      { "set": [ "input[2].progress_visible", "true" ] }
    ],
    "on_complete": [
      {
        "if": [
          {
            "and": [
              { "if": [ "input[1].trees" ] },
              { "if": [ "input[3].woodcutter" ] }
            ]
          },
          {
            "give": [ "input[0].card_id", "log", { "rand": [ "2", "5" ] } ]
          }
        ]
      },
      {
        "if": [
          {
            "and": [
              { "if": [ "input[1].food" ] },
              { "if": [ "input[3].forager" ] }
            ]
          },
          {
            "give": [ "input[0].card_id", "Food", { "rand": [ "1", "3" ] } ]
          }
        ]
      },
      {
        "enqueue": [ "fatigue_health", "input[3].card_id" ]
      },
      { "set": [ "input[2].ready", "true" ] },
      { "set": [ "input[2].progress_visible", "false" ] }
    ]
  },
  {
    "id": "fatigue_health",
    "input": [
      { "Health": { "if": [ "input[1].ready" ] } }
    ],
    "craft_time": { "value": [ "30" ] },
    "on_start": [
      { "set": [ "input[1].ready", "false" ] },
      { "set": [ "input[1].progress_visible", "true" ] }
    ],
    "on_complete": [
      { "set": [ "input[1].ready", "true" ] },
      { "set": [ "input[1].progress_visible", "false" ] }
    ]
  }
]